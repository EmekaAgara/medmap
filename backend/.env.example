# Copy to .env and fill in values.
PORT=4000
NODE_ENV=development
# MONGO_URI=mongodb://localhost:27017/medmap

# --- Interswitch Web Checkout
# @see https://docs.interswitchgroup.com/docs/web-checkout
#
# Sandbox (QuickStart table): merchant MX6072, pay item 9405967
# INTERSWITCH_MERCHANT_CODE=MX6072
# INTERSWITCH_PAYABLE_CODE=9405967
#
# Return URL — gateway POSTs txnref here after payment (do not trust resp; app/server use gettransaction)
# INTERSWITCH_REDIRECT_URL=https://YOUR_PUBLIC_API/api/v1/wallets/webpay/redirect
#
# INTERSWITCH_WEBPAY_MODE=TEST
# Web Redirect form action (defaults match docs)
# INTERSWITCH_WEBPAY_URL_TEST=https://newwebpay.qa.interswitchng.com/collections/w/pay
# INTERSWITCH_WEBPAY_URL_LIVE=https://newwebpay.interswitchng.com/collections/w/pay
#
# Confirming transaction (GET gettransaction.json)
# INTERSWITCH_BASE_URL=https://qa.interswitchng.com
# INTERSWITCH_GETTRANSACTION_PATH=/collections/api/v1/gettransaction.json
# INTERSWITCH_REQUERY_BASE_TEST=https://qa.interswitchng.com
# INTERSWITCH_REQUERY_BASE_LIVE=https://webpay.interswitchng.com
#
# Optional Hash for gettransaction:
# INTERSWITCH_MAC_KEY=
#
# Optional: Pay Bill API instead of Web Redirect form
# INTERSWITCH_USE_PAY_BILL=false
# INTERSWITCH_PAY_BILL_PATH=/collections/api/v1/pay-bill
#
# Webhooks (optional): POST /api/v1/wallets/webhooks/interswitch
# INTERSWITCH_WEBHOOK_SECRET=
#
# Polling /fund/verify uses gettransaction unless:
# INTERSWITCH_ENABLE_SERVER_REQUERY=false
#
# PLATFORM_FEE_BPS=500
