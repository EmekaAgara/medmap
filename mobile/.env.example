# Copy to .env and adjust. Variables must be prefixed with EXPO_PUBLIC_ to be visible in the app.
# Restart Expo after changes (`npx expo start -c`).

# --- Production / staging (required for EAS / TestFlight / Play) ---
# Host only is OK — /api/v1 is appended automatically if missing:
# EXPO_PUBLIC_API_URL=https://your-api.example.com
# Or full path:
# EXPO_PUBLIC_API_URL=https://your-api.example.com/api/v1
#
# Optional: Socket.IO origin if it differs from REST (must NOT include /api/v1):
# EXPO_PUBLIC_SOCKET_URL=https://your-api.example.com
#
# Optional port override for dev LAN / emulator (default 4000):
# EXPO_PUBLIC_API_PORT=4000

# --- Android emulator (API running on your Mac/PC host) ---
# Use special loopback — localhost inside the emulator is the emulator itself, not your machine.
# EXPO_PUBLIC_ANDROID_EMULATOR=1
# EXPO_PUBLIC_API_PORT=4000

# --- iOS Simulator: leave unset in dev; LAN auto-detection uses Expo dev server host. ---
